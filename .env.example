ANTHROPIC_API_KEY=sk-ant-your-key-here

# Default model for all routes (can be overridden per-route below)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-route overrides — omit to use ANTHROPIC_MODEL
# Extract is simple text extraction; Haiku is fine and much cheaper
EXTRACT_MODEL=claude-haiku-4-5-20251001
# Prefill rates 20+ checkpoints; test Haiku vs Sonnet for your use case
# PREFILL_MODEL=claude-haiku-4-5-20251001
# Suggestions require nuanced teaching advice; Sonnet recommended
# SUGGESTIONS_MODEL=claude-sonnet-4-6

# Reverse-proxy hops in front of this container (nginx/caddy/cloudflare = 1).
# The rate limiter keys off the X-Forwarded-For entry `hops` from the end so a
# client can't spoof it for a fresh bucket. Set 0 only if you expose 3000 directly.
TRUSTED_PROXY_HOPS=1
